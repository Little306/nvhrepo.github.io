<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CODEX VIP PRO</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:linear-gradient(135deg,#0f172a,#111827,#1e3a8a);
height:100vh;
display:flex;
justify-content:center;
align-items:center;
overflow:hidden;
color:white;
}

.card{
width:430px;
padding:35px;
background:rgba(255,255,255,.08);
backdrop-filter:blur(18px);
border-radius:25px;
border:1px solid rgba(255,255,255,.15);
box-shadow:0 20px 50px rgba(0,0,0,.4);
text-align:center;
animation:fade .8s;
}

.logo{
font-size:55px;
margin-bottom:10px;
}

h1{
font-size:32px;
margin-bottom:10px;
}

p{
opacity:.8;
margin-bottom:30px;
}

button{
width:100%;
padding:15px;
border:none;
border-radius:15px;
font-size:17px;
cursor:pointer;
margin-top:15px;
transition:.3s;
font-weight:600;
}

.start{
background:#2563eb;
color:#fff;
}

.start:hover{
transform:translateY(-3px);
box-shadow:0 15px 30px rgba(37,99,235,.4);
}

.github{
background:#fff;
color:#111;
}

.github:hover{
transform:translateY(-3px);
}

.footer{
margin-top:25px;
font-size:13px;
opacity:.6;
}

@keyframes fade{
from{
opacity:0;
transform:translateY(30px);
}
to{
opacity:1;
transform:translateY(0);
}
}
</style>

</head>

<body>

<div class="card">

<div class="logo">🚀</div>

<h1>CODEX VIP PRO</h1>

<p>
AI HTML Generator<br>
Premium Interface 2026
</p>

<button class="start">
✨ New Project
</button>

<button class="github">
📂 Open Workspace
</button>

<div class="footer">
Version 15.0 Premium
</div>

</div>

</body>
</html>
